# ─────────────────────────────────────────────────────────────────
# NNLOMNE Notify — Environment Variables
# Copy this file to .env.local for local development,
# or paste the values into your Vercel project settings.
# ─────────────────────────────────────────────────────────────────

# Firebase Admin SDK (Server-side only — used by Next.js API routes)
# Paste the full contents of your Firebase service-account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Twilio credentials (Server-side only)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Client SDK (Public — safe to expose, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
